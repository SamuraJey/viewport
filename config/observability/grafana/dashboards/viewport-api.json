        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(http_requests_inprogress{job=\"viewport-api\"})",
          "legendFormat": "{{service}}{{route}}{{status}}{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
