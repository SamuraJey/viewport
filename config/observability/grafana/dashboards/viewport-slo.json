      "id": 1,
      "type": "timeseries",
      "title": "Availability SLI (non-5xx)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (sum(rate(http_requests_total{job=\"viewport-api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"viewport-api\"}[5m])), 1))",
          "legendFormat": "{{service}}{{route}}{{status}}{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
