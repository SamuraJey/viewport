# Local observability defaults for docker-compose.observability.yml.
# Operator TODO: copy to a private env file and replace all credentials/ports for staging/production.
DEPLOYMENT_ENVIRONMENT=local
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-only
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
ALERTMANAGER_PORT=9093
LOKI_PORT=3100
TEMPO_HTTP_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133
ALLOY_PORT=12345
# Local placeholder only. Use a least-privilege user and secret manager in production.
POSTGRES_EXPORTER_DSN=postgresql://viewport:viewport@postgres:5432/viewport?sslmode=disable
